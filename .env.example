# AI Configuration
# Set to 'local' to use Ollama, 'cloud' for OpenAI, 'auto' to try both, 'none' for fallback
CONCIERGE_LLM_PROVIDER=local

# For local Ollama
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_MODEL=deepseek-r1:8b
LOCAL_LLM_TIMEOUT_SECONDS=8

# For cloud (OpenAI compatible)
CLOUD_LLM_BASE_URL=https://api.openai.com/v1
CLOUD_LLM_MODEL=gpt-4o-mini
CLOUD_LLM_API_KEY=your_api_key_here
CLOUD_LLM_TIMEOUT_SECONDS=10